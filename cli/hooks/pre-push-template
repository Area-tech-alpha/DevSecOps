#!/usr/bin/env bash
# ALPHA-CI-HOOK: installed by alpha-ci
set -euo pipefail

# Alpha CI — pre-push git hook template
# Executa o pipeline sem instalar pacotes dentro do repositório alvo.

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -z "$REPO_ROOT" ]; then
  echo "[alpha-ci] Not a git repository, skipping alpha-ci checks."
  exit 0
fi
cd "$REPO_ROOT"

print_auth_help() {
  echo -e "\n\033[0;31m[alpha-ci] ERROR: Failed to execute @area-tech-alpha/alpha-ci.\033[0m"
  echo "[alpha-ci] This usually means you are not authenticated to GitHub Packages."
  echo "[alpha-ci] Run the setup script to fix this:"

  if [[ "${OSTYPE:-}" == "msys" || "${OSTYPE:-}" == "cygwin" ]]; then
    echo -e "\033[0;33m  (Windows PowerShell):\033[0m"
    echo -e "\033[0;36m  irm https://raw.githubusercontent.com/Area-tech-alpha/DevSecOps/main/cli/setup-auth.ps1 | iex\033[0m"
  else
    echo -e "\033[0;33m  (Linux / macOS):\033[0m"
    echo -e "\033[0;36m  bash <(curl -fsSL https://raw.githubusercontent.com/Area-tech-alpha/DevSecOps/main/cli/setup-auth.sh)\033[0m"
  fi
  echo ""
}

echo "[alpha-ci] Running pre-push checks..."

run_alpha_ci() {
  if [ -n "${ALPHA_CI_CMD:-}" ]; then
    echo "[alpha-ci] Executing: ${ALPHA_CI_CMD} all"
    "${ALPHA_CI_CMD}" all
    return $?
  fi

  if command -v alpha-ci >/dev/null 2>&1; then
    echo "[alpha-ci] Executing: alpha-ci all"
    alpha-ci all
    return $?
  fi

  if [ -x "./node_modules/.bin/alpha-ci" ]; then
    echo "[alpha-ci] Executing: ./node_modules/.bin/alpha-ci all"
    ./node_modules/.bin/alpha-ci all
    return $?
  fi

  if command -v npm >/dev/null 2>&1; then
    echo "[alpha-ci] alpha-ci not found globally; running through npm exec without modifying this project..."
    npm exec --yes --package @area-tech-alpha/alpha-ci -- alpha-ci all
    local exit_code=$?
    [ "$exit_code" -ne 0 ] && print_auth_help
    return "$exit_code"
  fi

  echo "[alpha-ci] alpha-ci not available and npm not found. Skipping checks (allow push)."
  return 0
}

set +e
run_alpha_ci
EXIT_CODE=$?
set -e

if [ $EXIT_CODE -ne 0 ]; then
  echo "[alpha-ci] Pipeline failed (exit $EXIT_CODE). Aborting push."
  exit $EXIT_CODE
else
  echo "[alpha-ci] Pipeline passed — continuing push."
  exit 0
fi
