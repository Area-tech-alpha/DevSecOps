#!/usr/bin/env bash
set -euo pipefail

# Alpha CI — pre-push git hook template
# Instala localmente (se necessário) e executa o pipeline (bloqueia o push em falha)

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -z "$REPO_ROOT" ]; then
  echo "[alpha-ci] Not a git repository, skipping alpha-ci checks."
  exit 0
fi
cd "$REPO_ROOT"

echo "[alpha-ci] Running pre-push checks..."

# Prefer local project bin, then global, else attempt to install locally (--no-save)
ALPHA_CI_CMD=""
if [ -x "./node_modules/.bin/alpha-ci" ]; then
  ALPHA_CI_CMD="./node_modules/.bin/alpha-ci"
elif command -v alpha-ci >/dev/null 2>&1; then
  ALPHA_CI_CMD="alpha-ci"
else
  if command -v npm >/dev/null 2>&1; then
    echo "[alpha-ci] alpha-ci not found — attempting local installation..."
    if npm install --no-save @area-tech-alpha/alpha-ci 2>&1; then
      if [ -x "./node_modules/.bin/alpha-ci" ]; then
        ALPHA_CI_CMD="./node_modules/.bin/alpha-ci"
      fi
    else
      echo -e "\n\033[0;31m[alpha-ci] ERROR: Failed to install @area-tech-alpha/alpha-ci locally.\033[0m"
      echo "[alpha-ci] This usually means you are not authenticated to GitHub Packages."
      echo "[alpha-ci] Run the setup script to fix this:"
      
      if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]]; then
        echo -e "\033[0;33m  (Windows PowerShell):\033[0m"
        echo -e "\033[0;36m  irm https://raw.githubusercontent.com/Area-tech-alpha/DevSecOps/main/cli/setup-auth.ps1 | iex\033[0m"
      else
        echo -e "\033[0;33m  (Linux / macOS):\033[0m"
        echo -e "\033[0;36m  bash <(curl -fsSL https://raw.githubusercontent.com/Area-tech-alpha/DevSecOps/main/cli/setup-auth.sh)\033[0m"
      fi
      echo ""
    fi
  fi
fi

if [ -z "${ALPHA_CI_CMD}" ]; then
  echo "[alpha-ci] Skipping security checks (pipeline not available)."
  exit 0
fi

echo "[alpha-ci] Executing: $ALPHA_CI_CMD all"
"$ALPHA_CI_CMD" all
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo "[alpha-ci] Pipeline failed (exit $EXIT_CODE). Aborting push."
  exit $EXIT_CODE
else
  echo "[alpha-ci] Pipeline passed — continuing push."
  exit 0
fi
